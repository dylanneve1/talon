{
  "name": "talon-telegram-bot",
  "version": "1.0.0",
  "description": "Claude-powered Telegram bot with full tool access, streaming, cron jobs, and group awareness",
  "author": "Dylan Neve",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dylanneve1/talon.git"
  },
  "keywords": [
    "telegram",
    "bot",
    "claude",
    "ai",
    "mcp",
    "agent-sdk",
    "chatbot"
  ],
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "bin": {
    "talon": "./bin/talon.js"
  },
  "scripts": {
    "start": "node --import tsx src/index.ts",
    "cli": "node --import tsx src/cli.ts",
    "setup": "node --import tsx src/cli.ts setup",
    "dev": "node --import tsx --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/ --ignore-pattern '**/__tests__/**'",
    "format": "prettier --write src/ prompts/",
    "format:check": "prettier --check src/ prompts/"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@clack/prompts": "^1.1.0",
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opencode-ai/sdk": "^1.2.27",
    "croner": "^10.0.1",
    "grammy": "^1.41.1",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "telegram": "^2.26.22",
    "tsx": "^4.21.0",
    "write-file-atomic": "^7.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/write-file-atomic": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.0",
    "fast-check": "^4.6.0",
    "oxlint": "^1.55.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
