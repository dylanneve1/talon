{
  "name": "talon-agent",
  "version": "1.0.0",
  "description": "Multi-frontend AI agent with full tool access, streaming, cron jobs, and plugin system",
  "author": "Dylan Neve",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dylanneve1/talon.git"
  },
  "keywords": [
    "telegram",
    "bot",
    "claude",
    "ai",
    "mcp",
    "agent-sdk",
    "chatbot"
  ],
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "talon": "./bin/talon.js"
  },
  "files": [
    "bin/",
    "src/",
    "prompts/",
    "README.md",
    "tsconfig.json"
  ],
  "scripts": {
    "build:binary": "bun build --compile --minify src/index.ts --outfile talon-bun",
    "start": "tsx src/index.ts",
    "cli": "tsx src/cli.ts",
    "setup": "tsx src/cli.ts setup",
    "dev": "tsx --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "knip": "knip",
    "format": "prettier --write src/ prompts/",
    "format:check": "prettier --check src/ prompts/"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.92",
    "@clack/prompts": "^1.2.0",
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/sdk": "^1.3.17",
    "big-integer": "^1.6.52",
    "cheerio": "^1.2.0",
    "croner": "^10.0.1",
    "grammy": "^1.42.0",
    "marked": "^17.0.6",
    "p-retry": "^8.0.0",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "telegram": "^2.26.22",
    "tsx": "^4.21.0",
    "undici": "^8.0.2",
    "write-file-atomic": "^7.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/node": "^25.5.2",
    "@types/write-file-atomic": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.2",
    "fast-check": "^4.6.0",
    "knip": "^6.3.0",
    "oxlint": "^1.58.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
