{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "testRunner": "vitest",
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "mutate": [
    "src/core/**/*.ts",
    "src/storage/**/*.ts",
    "src/util/config.ts",
    "src/util/workspace.ts",
    "!src/**/__tests__/**"
  ],
  "reporters": ["clear-text", "html"],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "concurrency": 4,
  "timeoutMS": 30000
}
