# ── Required ────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TALON_BOT_TOKEN=

# ── Optional: Model & AI ───────────────────────────────────────────────────

# Default AI model (claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5)
# TALON_MODEL=claude-sonnet-4-6

# Max concurrent AI queries (default 1 — safe with global bridge context)
# TALON_CONCURRENCY=1

# ── Optional: Userbot (full history access) ────────────────────────────────

# Get these from https://my.telegram.org/apps
# Without these, bot uses in-memory history only
# Then run: npx tsx src/login.ts (one-time phone login)
# TALON_API_ID=
# TALON_API_HASH=

# ── Optional: Pulse (periodic engagement) ──────────────────────────────────

# Set to 0 to disable pulse entirely
# TALON_PULSE=1

# Pulse check interval in milliseconds (default 300000 = 5 minutes)
# TALON_PULSE_INTERVAL_MS=300000

# ── Optional: Admin ────────────────────────────────────────────────────────

# Your Telegram user ID — enables /admin commands
# TALON_ADMIN_USER_ID=

# ── Optional: Tuning ──────────────────────────────────────────────────────

# Workspace directory (default: ./workspace)
# TALON_WORKSPACE=

# Max message length before splitting (default 4000)
# TALON_MAX_MESSAGE_LENGTH=4000

# Pino log level: trace, debug, info, warn, error (always trace by default)
# TALON_LOG_LEVEL=trace

# Node environment (set to "production" for JSON logs without pino-pretty)
# NODE_ENV=production
