# Required: Telegram bot token from @BotFather
TALON_BOT_TOKEN=

# Model (default: claude-sonnet-4-6)
# TALON_MODEL=claude-sonnet-4-6

# System prompt override
# TALON_SYSTEM_PROMPT="You are a helpful assistant."

# Max thinking tokens per turn (default: 10000)
# TALON_MAX_THINKING_TOKENS=10000

# Verbose logging (default: false)
# TALON_VERBOSE=1
